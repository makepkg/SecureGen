---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Backup Tools — SecureGen" page="tools">
  <section class="page-header">
    <p class="breadcrumb">
      <a href="/SecureGen/">Home</a> / Tools
    </p>
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;margin-bottom:0.25rem;">
      <h1 style="margin:0;" data-i18n="title">Backup Tools</h1>
      <div style="font-size:1.3rem;display:flex;gap:0.5rem;">
        <button id="lang-en" style="background:none;border:none;cursor:pointer;font-size:1.3rem;opacity:1;" title="English">🇬🇧</button>
        <button id="lang-ru" style="background:none;border:none;cursor:pointer;font-size:1.3rem;opacity:0.4;" title="Русский">🇷🇺</button>
        <button id="lang-zh" style="background:none;border:none;cursor:pointer;font-size:1.3rem;opacity:0.4;" title="中文">🇨🇳</button>
      </div>
    </div>
    <p class="description" data-i18n="description">
      Offline tools for managing encrypted backup files from your device.
    </p>
  </section>

  <section class="tool-cards">
    <div class="tool-card">
      <div class="tool-icon">🔓</div>
      <h2 data-i18n="card1.title">Decrypt & Edit Backups</h2>
      <p class="tool-description" data-i18n="card1.desc">
        Decrypt your .enc backup files in the browser. View and edit TOTP keys or passwords, 
        change the encryption password, re-encrypt and save. Your data never leaves this device — 
        all processing is local.
      </p>
      <ul class="feature-list">
        <li data-i18n="card1.f1">✓ Works offline</li>
        <li data-i18n="card1.f2">✓ Edit TOTP keys</li>
        <li data-i18n="card1.f3">✓ Edit passwords</li>
        <li data-i18n="card1.f4">✓ Re-encrypt & export</li>
      </ul>
      <a href="/SecureGen/tools-app.html" class="btn-tool" data-i18n="card1.btn">Open Backup Editor →</a>
    </div>

    <div class="tool-card">
      <div class="tool-icon">💾</div>
      <h2 data-i18n="card2.title">Offline Use</h2>
      <p class="tool-description" data-i18n="card2.desc">
        Save the editor to your computer for use without any internet connection.
      </p>
      <ol class="steps-list">
        <li data-i18n="card2.s1">Open Backup Editor above</li>
        <li data-i18n="card2.s2">Press Ctrl+S (or Cmd+S on Mac) to save the page</li>
        <li data-i18n="card2.s3">Open the saved HTML file in any browser — it works fully offline</li>
      </ol>
      <p class="note" data-i18n="card2.note">Note: The editor has no external dependencies.</p>
    </div>
  </section>

  <section class="how-it-works">
    <h2 data-i18n="how.title">How It Works</h2>
    <div class="workflow">
      <div class="workflow-step">
        <div class="step-icon">📤</div>
        <h3 data-i18n="step1.title">Export from device</h3>
        <p data-i18n="step1.desc">Go to web cabinet → TOTP or Passwords → Export → download .enc file</p>
      </div>
      <div class="workflow-arrow">→</div>
      <div class="workflow-step">
        <div class="step-icon">🔓</div>
        <h3 data-i18n="step2.title">Open in editor</h3>
        <p data-i18n="step2.desc">Click 'Open Backup Editor', upload the .enc file, enter your admin password</p>
      </div>
      <div class="workflow-arrow">→</div>
      <div class="workflow-step">
        <div class="step-icon">📥</div>
        <h3 data-i18n="step3.title">Import back</h3>
        <p data-i18n="step3.desc">Edit entries, click 'Save Encrypted', import the new .enc file on any device</p>
      </div>
    </div>
  </section>

  <section class="security-note">
    <div class="callout callout-info">
      <div class="callout-header">
        <span class="callout-icon">🛡️</span>
        <strong data-i18n="security.title">Security</strong>
      </div>
      <p>
        <span data-i18n="security.p">This tool runs entirely in your browser using the Web Crypto API (AES-CBC + PBKDF2). 
        No data is sent to any server. The encryption format is identical to the device — 
        files encrypted here can be imported directly to your ESP32.</span>
      </p>
      <p class="source-link">
        View source: 
        <a href="https://github.com/makepkg/SecureGen/blob/main/decrypt_export.html" target="_blank" rel="noopener noreferrer">
          github.com/makepkg/SecureGen/blob/main/decrypt_export.html
        </a>
      </p>
    </div>
  </section>
</Layout>

<script is:inline>
const TOOLS_I18N = {
