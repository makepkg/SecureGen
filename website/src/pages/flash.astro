let flashLang = localStorage.getItem('site_lang') || 'en';

function trF(k) { return FLASH_I18N[flashLang]?.[k] ?? FLASH_I18N.en[k] ?? k; }

function setFlashLang(l) {
flashLang = l;
localStorage.setItem('site_lang', l);
if (typeof applyNavLang === 'function') applyNavLang();
document.getElementById('lang-en').style.opacity = l === 'en' ? '1' : '0.4';
document.getElementById('lang-ru').style.opacity = l === 'ru' ? '1' : '0.4';
document.getElementById('lang-zh').style.opacity = l === 'zh' ? '1' : '0.4';
document.querySelectorAll('[data-i18n]').forEach(el => {
el.textContent = trF(el.dataset.i18n);
});
}

document.addEventListener('DOMContentLoaded', () => {
  setFlashLang(flashLang);
  document.getElementById('lang-en').addEventListener('click', () => setFlashLang('en'));
  document.getElementById('lang-ru').addEventListener('click', () => setFlashLang('ru'));
  document.getElementById('lang-zh').addEventListener('click', () => setFlashLang('zh'));
});
