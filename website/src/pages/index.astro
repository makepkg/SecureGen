let indexLang = localStorage.getItem('site_lang') || 'en';

function trI(k) { 
  return INDEX_I18N[indexLang]?.[k] ?? INDEX_I18N.en[k] ?? k; 
}

function setIndexLang(l) {
  indexLang = l;
  localStorage.setItem('site_lang', l);
  if (typeof applyNavLang === 'function') applyNavLang();
  document.getElementById('lang-en').style.opacity = l === 'en' ? '1' : '0.4';
  document.getElementById('lang-ru').style.opacity = l === 'ru' ? '1' : '0.4';
  document.getElementById('lang-zh').style.opacity = l === 'zh' ? '1' : '0.4';
  document.querySelectorAll('[data-i18n]').forEach(el => {
    el.textContent = trI(el.dataset.i18n);
  });
}

document.addEventListener('DOMContentLoaded', () => {
  setIndexLang(indexLang);
  document.getElementById('lang-en').addEventListener('click', () => setIndexLang('en'));
  document.getElementById('lang-ru').addEventListener('click', () => setIndexLang('ru'));
  document.getElementById('lang-zh').addEventListener('click', () => setIndexLang('zh'));

  // Board tabs switching
  const boardTabs = document.querySelectorAll('.board-tab');
  const boardCards = document.querySelectorAll('.board-card');

  // Initialize the first active card with proper styles
  const initialActiveCard = document.querySelector('.board-card.active');
  if (initialActiveCard) {
    initialActiveCard.style.opacity = '1';
    initialActiveCard.style.transform = 'translateY(0)';
  }

  boardTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const targetBoard = tab.dataset.board;
      
      // Update active tab
      boardTabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      
      // Fade out current card
      const currentCard = document.querySelector('.board-card.active');
      if (currentCard) {
        currentCard.style.opacity = '0';
        currentCard.style.transform = 'translateY(10px)';
        
        setTimeout(() => {
          currentCard.classList.remove('active');
          
          // Fade in new card
          const newCard = document.querySelector(`[data-board-content="${targetBoard}"]`);
          if (newCard) {
            newCard.classList.add('active');
            // Force reflow
            newCard.offsetHeight;
            newCard.style.opacity = '1';
            newCard.style.transform = 'translateY(0)';
          }
        }, 300);
      }
    });
  });
});
</script>

